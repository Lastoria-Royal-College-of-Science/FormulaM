{
  "name": "FormulaM - Node.js",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:18-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "src/formula.js",
        "package.json"
      ]
    },
    "vscode": {
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      },
      "extensions": [
        "ms-vscode.js-debug",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "updateContentCommand": "npm install && echo '✅ Dependencies installed'",
  "postAttachCommand": "npm test"
}
